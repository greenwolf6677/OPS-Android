# ==================== تقرير الأصناف الأكثر مبيعاً ====================
<TopProductItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.rank)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: root.name
        size_hint_x: 0.4
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: str(root.total_qty)
        size_hint_x: 0.12
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total_sales:.2f}"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: f"{root.avg_price:.2f}"
        size_hint_x: 0.12
        font_name: 'ArabicFont'


<TopProductsReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "🏆 الأصناف الأكثر مبيعاً"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "من تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.start_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_start_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "إلى تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.end_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_end_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "عدد النتائج"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Spinner:
                    text: root.limit
                    values: ["5", "10", "20", "50", "100"]
                    font_name: 'ArabicFont'
                    size_hint_y: None
                    height: dp(40)
                    on_text: root.limit = self.text
            
            Button:
                text: "عرض التقرير 🔍"
                font_name: 'ArabicFont'
                background_color: (0.2, 0.6, 0.2, 1)
                size_hint_x: None
                width: dp(120)
                on_press: root.load_report()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(20)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: (0.95, 0.95, 0.95, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "إجمالي المنتجات:"
                font_size: sp(14)
                font_name: 'ArabicFont'
            Label:
                text: root.total_products
                font_size: sp(24)
                bold: True
                font_name: 'ArabicFont'
                color: (0.2, 0.5, 0.8, 1)
            
            Label:
                text: "إجمالي المبيعات:"
                font_size: sp(14)
                font_name: 'ArabicFont'
            Label:
                text: root.total_sales
                font_size: sp(24)
                bold: True
                font_name: 'ArabicFont'
                color: (0.2, 0.6, 0.2, 1)
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "الترتيب"
                size_hint_x: 0.08
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "اسم المنتج"
                size_hint_x: 0.4
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الكمية المباعة"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "إجمالي المبيعات"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "متوسط السعر"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: products_list
            viewclass: 'TopProductItem'
        
        Button:
            text: "🖨️ طباعة التقرير PDF"
            font_name: 'ArabicFont'
            background_color: (0.2, 0.5, 0.7, 1)
            size_hint_y: None
            height: dp(50)
            on_press: root.print_report()


# ==================== تقرير الأصناف الأقل مبيعاً ====================
<BottomProductItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.rank)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: root.name
        size_hint_x: 0.4
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: str(root.total_qty)
        size_hint_x: 0.12
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total_sales:.2f}"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        color: (0.8, 0.2, 0.2, 1)
    
    Label:
        text: str(root.in_stock)
        size_hint_x: 0.12
        font_name: 'ArabicFont'
        color: (0.8, 0.5, 0.2, 1) if root.in_stock <= 10 else (0.2, 0.6, 0.2, 1)


