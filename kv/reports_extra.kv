# ==================== تقرير أرباح المنتجات ====================
<ProfitItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.rank)
        size_hint_x: 0.06
        font_name: 'ArabicFont'
    
    Label:
        text: root.barcode
        size_hint_x: 0.1
        font_name: 'ArabicFont'
    
    Label:
        text: root.name
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: str(root.qty_sold)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total_sales:.2f}"
        size_hint_x: 0.1
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total_cost:.2f}"
        size_hint_x: 0.1
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.profit:.2f}"
        size_hint_x: 0.1
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: f"{root.profit_margin:.1f}%"
        size_hint_x: 0.08
        font_name: 'ArabicFont'
        color: (0.8, 0.5, 0.2, 1)


<ProfitReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "💰 تقرير أرباح المنتجات"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "من تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.start_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_start_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "إلى تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.end_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_end_date_picker()
            
            Button:
                text: "عرض التقرير 🔍"
                font_name: 'ArabicFont'
                background_color: (0.2, 0.6, 0.2, 1)
                size_hint_x: None
                width: dp(120)
                on_press: root.load_report()
        
        GridLayout:
            size_hint_y: None
            height: dp(80)
            cols: 3
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "إجمالي الربح"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_profit
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.6, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "إجمالي المبيعات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_sales
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.5, 0.8, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "هامش الربح"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.profit_margin
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.8, 0.5, 0.2, 1)
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "ر"
                size_hint_x: 0.06
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "باركود"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المنتج"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الكمية"
                size_hint_x: 0.08
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المبيعات"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "التكلفة"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الربح"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الهامش"
                size_hint_x: 0.08
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: products_list
            viewclass: 'ProfitItem'
        
        Button:
            text: "🖨️ طباعة التقرير PDF"
            font_name: 'ArabicFont'
            background_color: (0.2, 0.5, 0.7, 1)
            size_hint_y: None
            height: dp(50)
            on_press: root.print_report


# ==================== تقرير الديون ====================
<DebtItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(50)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.debt_id)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: root.name
        size_hint_x: 0.25
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: root.phone
        size_hint_x: 0.12
        font_name: 'ArabicFont'
    
    Label:
        text: root.balance
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        color: (0.8, 0.2, 0.2, 1)
    
    Label:
        text: root.total_purchases
        size_hint_x: 0.15
        font_name: 'ArabicFont'
    
    Label:
        text: root.total_payments
        size_hint_x: 0.15
        font_name: 'ArabicFont'


<DebtReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "👥 تقرير الديون"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        TabbedPanel:
            size_hint_y: 0.95
            
            TabbedPanelItem:
                text: "👥 ديون الزبائن"
                
                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10)
                    spacing: dp(10)
                    
                    BoxLayout:
                        size_hint_y: None
                        height: dp(80)
                        spacing: dp(20)
                        padding: dp(10)
                        canvas.before:
                            Color:
                                rgba: (0.95, 0.95, 0.95, 1)
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        
                        Label:
                            text: "إجمالي ديون الزبائن:"
                            font_size: sp(16)
                            font_name: 'ArabicFont'
                        Label:
                            text: root.total_customer_debt
                            font_size: sp(28)
                            bold: True
                            font_name: 'ArabicFont'
                            color: (0.8, 0.2, 0.2, 1)
                        
                        Label:
                            text: "عدد الزبائن المدينين:"
                            font_size: sp(16)
                            font_name: 'ArabicFont'
                        Label:
                            text: root.debt_customers_count
                            font_size: sp(28)
                            bold: True
                            font_name: 'ArabicFont'
                            color: (0.8, 0.5, 0.2, 1)
                    
                    BoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(5)
                        padding: dp(5)
                        canvas.before:
                            Color:
                                rgba: (0.2, 0.3, 0.4, 1)
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        
                        Label:
                            text: "الرقم"
                            size_hint_x: 0.08
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                        Label:
                            text: "اسم الزبون"
                            size_hint_x: 0.25
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                        Label:
                            text: "الهاتف"
                            size_hint_x: 0.12
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                        Label:
                            text: "الرصيد الحالي"
                            size_hint_x: 0.15
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                        Label:
                            text: "إجمالي المشتريات"
                            size_hint_x: 0.15
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                        Label:
                            text: "إجمالي المدفوعات"
                            size_hint_x: 0.15
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                    
                    RecycleView:
                        id: customer_debt_list
                        viewclass: 'DebtItem'
            
            TabbedPanelItem:
                text: "🏭 ديون الموردين"
                
                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10)
                    spacing: dp(10)
                    
                    BoxLayout:
                        size_hint_y: None
                        height: dp(80)
                        spacing: dp(20)
                        padding: dp(10)
                        canvas.before:
                            Color:
                                rgba: (0.95, 0.95, 0.95, 1)
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        
                        Label:
                            text: "إجمالي ديون الموردين:"
                            font_size: sp(16)
                            font_name: 'ArabicFont'
                        Label:
                            text: root.total_supplier_debt
                            font_size: sp(28)
                            bold: True
                            font_name: 'ArabicFont'
                            color: (0.8, 0.2, 0.2, 1)
                        
                        Label:
                            text: "عدد الموردين المدينين:"
                            font_size: sp(16)
                            font_name: 'ArabicFont'
                        Label:
                            text: root.debt_suppliers_count
                            font_size: sp(28)
                            bold: True
                            font_name: 'ArabicFont'
                            color: (0.8, 0.5, 0.2, 1)
                    
                    BoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(5)
                        padding: dp(5)
                        canvas.before:
                            Color:
                                rgba: (0.2, 0.3, 0.4, 1)
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        
                        Label:
                            text: "الرقم"
                            size_hint_x: 0.08
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
                        Label:
                            text: "اسم المورد"
                            size_hint_x: 0.25
                            font_name: 'ArabicFont'
                            color: (1, 1, 1, 1)
