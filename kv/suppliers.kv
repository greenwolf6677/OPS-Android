<SupplierItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(50)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.supplier_id)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: root.name
        size_hint_x: 0.25
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: root.mobile
        size_hint_x: 0.15
        font_name: 'ArabicFont'
    
    Label:
        text: root.address
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: root.balance
        size_hint_x: 0.12
        font_name: 'ArabicFont'
        color: root.balance_color
    
    Button:
        text: "تحديد"
        size_hint_x: 0.1
        font_name: 'ArabicFont'
        background_color: (0.3, 0.5, 0.8, 1)
        on_press: 
            app.root.get_screen('suppliers').select_supplier(root.supplier_id)


<SuppliersScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # الإطار العلوي
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "📦 إدارة الموردين والديون"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        # الإطار الرئيسي
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(15)
            
            # الجهة اليسرى: الإحصائيات
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.28
                spacing: dp(10)
                
                # إطار إجمالي الديون
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.95, 0.95, 0.95, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "إجمالي الديون"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                    Label:
                        text: root.total_debt
                        font_size: sp(28)
                        bold: True
                        font_name: 'ArabicFont'
                        color: (0.8, 0.2, 0.2, 1)
                
                # إطار عدد الموردين
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.95, 0.95, 0.95, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "عدد الموردين"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                    Label:
                        text: root.total_suppliers
                        font_size: sp(28)
                        bold: True
                        font_name: 'ArabicFont'
                        color: (0.2, 0.5, 0.8, 1)
                
                # إطار متوسط الدين
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.95, 0.95, 0.95, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "متوسط الدين"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                    Label:
                        text: root.avg_debt
                        font_size: sp(28)
                        bold: True
                        font_name: 'ArabicFont'
                        color: (0.2, 0.6, 0.2, 1)
            
            # الجهة اليمنى: المحتوى الرئيسي
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.72
                spacing: dp(10)
                
                # إطار الأزرار
                GridLayout:
                    size_hint_y: None
                    height: dp(120)
                    cols: 4
                    spacing: dp(5)
                    padding: dp(10)
                    
                    Button:
                        text: "➕ إضافة مورد"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.6, 0.2, 1)
                        on_press: root.add_supplier()
                    
                    Button:
                        text: "✏️ تعديل"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.5, 0.8, 1)
                        on_press: root.edit_supplier()
                    
                    Button:
                        text: "🗑️ حذف"
                        font_name: 'ArabicFont'
                        background_color: (0.8, 0.2, 0.2, 1)
                        on_press: root.delete_supplier()
                    
                    Button:
                        text: "🧹 مسح"
                        font_name: 'ArabicFont'
                        background_color: (0.5, 0.5, 0.5, 1)
                        on_press: root.clear_fields()
                    
                    Button:
                        text: "📋 فواتير المورد"
                        font_name: 'ArabicFont'
                        background_color: (0.6, 0.3, 0.8, 1)
                        on_press: root.show_supplier_invoices()
                    
                    Button:
                        text: "💰 مدفوعات المورد"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.7, 0.5, 1)
                        on_press: root.show_supplier_payments()
                    
                    Button:
                        text: "📊 كشف حساب"
                        font_name: 'ArabicFont'
                        background_color: (0.5, 0.4, 0.2, 1)
                        on_press: root.show_supplier_account()
                    
                    Button:
                        text: "🖨️ طباعة كشف الحساب"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.5, 0.7, 1)
                        on_press: root.print_supplier_account()
                
                # إطار حقول الإدخال
                ScrollView:
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(8)
                        padding: dp(10)
                        
                        Label:
                            text: "بيانات المورد"
                            font_size: sp(16)
                            bold: True
                            font_name: 'ArabicFont'
                            size_hint_y: None
                            height: dp(30)
                        
                        Label:
                            text: "اسم المورد:"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            size_hint_y: None
                            height: dp(25)
                        TextInput:
                            text: root.name
                            hint_text: "أدخل اسم المورد"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            multiline: False
                            size_hint_y: None
                            height: dp(45)
                            on_text: root.name = self.text
                        
                        Label:
                            text: "رقم الجوال:"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            size_hint_y: None
                            height: dp(25)
                        TextInput:
                            text: root.mobile
                            hint_text: "أدخل رقم الجوال"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            multiline: False
                            size_hint_y: None
                            height: dp(45)
                            on_text: root.mobile = self.text
                        
                        Label:
                            text: "العنوان:"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            size_hint_y: None
                            height: dp(25)
                        TextInput:
                            text: root.address
                            hint_text: "أدخل العنوان"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            multiline: False
                            size_hint_y: None
                            height: dp(45)
                            on_text: root.address = self.text
                        
                        Label:
                            text: "ملاحظات:"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            size_hint_y: None
                            height: dp(25)
                        TextInput:
                            text: root.notes
                            hint_text: "ملاحظات"
                            font_size: sp(12)
                            font_name: 'ArabicFont'
                            multiline: True
                            size_hint_y: None
                            height: dp(60)
                            on_text: root.notes = self.text
                        
                        # قسم السداد
                        Label:
                            text: "تسجيل سداد نقدي"
                            font_size: sp(16)
                            bold: True
                            font_name: 'ArabicFont'
                            size_hint_y: None
                            height: dp(30)
                        
                        BoxLayout:
                            size_hint_y: None
                            height: dp(50)
                            spacing: dp(10)
                            
                            Button:
                                text: "✅ تسجيل سداد"
                                font_name: 'ArabicFont'
                                background_color: (0.2, 0.6, 0.8, 1)
                                on_press: root.add_payment()
                            
                            Label:
                                text: "المبلغ المراد سداده:"
                                font_size: sp(12)
                                font_name: 'ArabicFont'
                            
                            TextInput:
                                text: root.payment_amount
                                hint_text: "0.00"
                                font_size: sp(12)
                                font_name: 'ArabicFont'
                                multiline: False
                                input_filter: 'float'
                                size_hint_x: 0.3
                                on_text: root.payment_amount = self.text
                
                # رأس الجدول
                BoxLayout:
                    size_hint_y: None
                    height: dp(45)
                    spacing: dp(5)
                    padding: dp(5)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.3, 0.4, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "ID"
                        size_hint_x: 0.08
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "اسم المورد"
                        size_hint_x: 0.25
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "رقم الجوال"
                        size_hint_x: 0.15
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "العنوان"
                        size_hint_x: 0.2
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "صافي الدين"
                        size_hint_x: 0.12
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: ""
                        size_hint_x: 0.1
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                
                # قائمة الموردين
                RecycleView:
                    id: suppliers_list
                    viewclass: 'SupplierItem'
                    
                    RecycleBoxLayout:
                        default_size: (None, dp(50))
                        default_size_hint: (1, None)
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: 'vertical'