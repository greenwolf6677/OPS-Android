<PaymentItem>:
    size_hint_y: None
    height: dp(45)
    canvas.before:
        Color:
            rgba: (0.98, 0.98, 0.98, 1) if root.index % 2 == 0 else (1, 1, 1, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(5)
        padding: [dp(10), 0]
        
        Label:
            text: root.amount
            size_hint_x: 0.25
            font_name: 'ArabicFont'
            color: (0.1, 0.5, 0.1, 1) # أخضر مالي
            bold: True
        
        Label:
            text: root.date
            size_hint_x: 0.45
            font_name: 'ArabicFont'
            color: (0.3, 0.3, 0.3, 1)
        
        Label:
            text: root.notes if root.notes else "-"
            size_hint_x: 0.3
            font_name: 'ArabicFont'
            color: (0.4, 0.4, 0.4, 1)
            halign: 'right'
            shorten: True # لقص الملاحظات الطويلة جداً
            shorten_from: 'right'


<CustomerPaymentsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # رأس الشاشة
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: [dp(10), 0]
            canvas.before:
                Color:
                    rgba: (0.15, 0.35, 0.5, 1) # أزرق داكن مختلف للتمييز
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [0, 0, dp(10), dp(10)]
            
            Label:
                text: "سجل مدفوعات: " + root.customer_name
                font_size: sp(18)
                bold: True
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
                halign: 'right'
            
            Button:
                text: "↩️"
                size_hint_x: None
                width: dp(50)
                background_normal: ''
                background_color: (0, 0, 0, 0)
                on_press: root.go_back()
        
        # بطاقة ملخص الإجمالي
        BoxLayout:
            size_hint_y: None
            height: dp(70)
            padding: dp(15)
            canvas.before:
                Color:
                    rgba: (0.92, 0.94, 0.95, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
            
            Label:
                text: "إجمالي ما تم دفعه:"
                font_size: sp(16)
                font_name: 'ArabicFont'
                color: (0.2, 0.2, 0.2, 1)
            
            Label:
                text: root.total_paid
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
                color: (0.1, 0.5, 0.1, 1)
        
        # جدول البيانات
        BoxLayout:
            orientation: 'vertical'
            canvas.before:
                Color:
                    rgba: (1, 1, 1, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            # رأس الجدول
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                canvas.before:
                    Color:
                        rgba: (0.2, 0.3, 0.4, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                
                HeaderLabel:
                    text: "المبلغ"
                    size_hint_x: 0.25
                HeaderLabel:
                    text: "التاريخ"
                    size_hint_x: 0.45
                HeaderLabel:
                    text: "الملاحظات"
                    size_hint_x: 0.3
            
            # القائمة
            RecycleView:
                id: payments_list
                viewclass: 'PaymentItem'
                RecycleBoxLayout:
                    default_size: None, dp(45)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    orientation: 'vertical'
                    spacing: dp(1)

# قالب مكرر لعناوين الجدول
<HeaderLabel@Label>:
    font_name: 'ArabicFont'
    bold: True
    color: (1, 1, 1, 1)