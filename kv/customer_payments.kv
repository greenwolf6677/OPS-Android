<PaymentItem>:
    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(5)
        
        Label:
            text: root.amount
            size_hint_x: 0.25
            font_name: 'ArabicFont'
            color: (0.2, 0.6, 0.2, 1)
        
        Label:
            text: root.date
            size_hint_x: 0.45
            font_name: 'ArabicFont'
        
        Label:
            text: root.notes
            size_hint_x: 0.3
            font_name: 'ArabicFont'


<CustomerPaymentsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "مدفوعات الزبون: " + root.customer_name
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            padding: dp(10)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: (0.95, 0.95, 0.95, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "إجمالي المدفوعات:"
                font_size: sp(18)
                font_name: 'ArabicFont'
            Label:
                text: root.total_paid
                font_size: sp(24)
                bold: True
                font_name: 'ArabicFont'
                color: (0.2, 0.6, 0.2, 1)
        
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "المبلغ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "تاريخ الدفع"
                size_hint_x: 0.45
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "ملاحظات"
                size_hint_x: 0.3
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: payments_list
            viewclass: 'PaymentItem'