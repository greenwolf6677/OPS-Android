<DashboardScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.1, 0.12, 0.15, 1) # خلفية داكنة عصرية
            Rectangle:
                pos: self.pos
                size: self.size
        
        # الإطار العلوي (Header)
        BoxLayout:
            size_hint_y: 0.12
            padding: [dp(15), dp(10)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.7
                Label:
                    text: root.store_name
                    font_size: '18sp'
                    bold: True
                    font_name: 'ArabicFont'
                    halign: 'left'
                    text_size: self.size
                Label:
                    text: f"مرحباً {root.user_name}  |  {root.current_time}"
                    font_size: '12sp'
                    font_name: 'ArabicFont'
                    color: (0.8, 0.8, 0.8, 1)
                    halign: 'left'
                    text_size: self.size

            Button:
                text: "تسجيل الخروج"
                size_hint_x: 0.3
                font_name: 'ArabicFont'
                background_color: (0.8, 0.2, 0.2, 1)
                on_release: root.logout()

        # شبكة الأزرار الرئيسية (Grid of Buttons)
        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(15)
                padding: dp(20)

                # الصف الأول
                BoxLayout:
                    size_hint_y: None
                    height: dp(110)
                    spacing: dp(15)
                    Button:
                        text: "🛒 الطلبيات"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.5, 0.8, 1)
                        on_release: root.go_to_screen('sales')
                    Button:
                        text: "📦 المنتجات"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.6, 0.2, 1)
                        on_release: root.go_to_screen('products')
                    Button:
                        text: "👥 الزبائن"
                        font_name: 'ArabicFont'
                        background_color: (0.6, 0.3, 0.8, 1)
                        on_release: root.go_to_screen('customers')

                # الصف الثاني
                BoxLayout:
                    size_hint_y: None
                    height: dp(110)
                    spacing: dp(15)
                    Button:
                        text: "↩️ المرتجع"
                        font_name: 'ArabicFont'
                        background_color: (0.8, 0.4, 0.2, 1)
                        on_release: root.go_to_screen('returns')
                    Button:
                        text: "📊 التقارير"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.7, 0.7, 1)
                        on_release: root.go_to_screen('reports')
                    Button:
                        text: "🏭 الموردين"
                        font_name: 'ArabicFont'
                        background_color: (0.9, 0.6, 0.1, 1)
                        on_release: root.go_to_screen('suppliers')

                # الصف الثالث
                BoxLayout:
                    size_hint_y: None
                    height: dp(110)
                    spacing: dp(15)
                    Button:
                        text: "📥 المشتريات"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.6, 0.8, 1)
                        on_release: root.go_to_screen('purchases')
                    Button:
                        text: "⚙️ الإعدادات"
                        font_name: 'ArabicFont'
                        background_color: (0.5, 0.5, 0.5, 1)
                        on_release: root.go_to_screen('users_management')
                    Button:
                        text: "ℹ️ حول البرنامج"
                        font_name: 'ArabicFont'
                        background_color: (0.5, 0.3, 0.7, 1)
                        on_release: root.go_to_screen('about')

        # التذييل (Footer)
        BoxLayout:
            size_hint_y: 0.06
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.25, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "برمجة وتصميم: أ. محمد موقدي (0598973359) | OPS 2026"
                font_size: '10sp'
                font_name: 'ArabicFont'
                color: (0.6, 0.6, 0.6, 1)
                halign: 'center'