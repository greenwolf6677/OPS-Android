<PurchaseItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(50)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.barcode
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        font_size: sp(12)
    
    Label:
        text: root.name
        size_hint_x: 0.3
        font_name: 'ArabicFont'
        font_size: sp(12)
        halign: 'right'
        text_size: self.size
    
    Label:
        text: f"{root.buy_price:.2f}"
        size_hint_x: 0.12
        font_name: 'ArabicFont'
        font_size: sp(12)
    
    Label:
        text: str(root.qty)
        size_hint_x: 0.1
        font_name: 'ArabicFont'
        font_size: sp(12)
    
    Label:
        text: f"{root.subtotal:.2f}"
        size_hint_x: 0.12
        font_name: 'ArabicFont'
        font_size: sp(12)
        color: (0.2, 0.6, 0.2, 1)
    
    Button:
        text: "🗑️"
        size_hint_x: 0.08
        font_name: 'ArabicFont'
        font_size: sp(14)
        background_color: (0.8, 0.2, 0.2, 1)
        on_press: 
            app.root.get_screen('purchases').remove_item(root.item_id)


<PurchasesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # الإطار العلوي
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            spacing: dp(10)
            
            Label:
                text: "فاتورة شراء"
                font_size: sp(24)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        # الإطار الرئيسي
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(15)
            
            # الجهة اليسرى: الإحصائيات
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.28
                spacing: dp(10)
                
                # إطار إجمالي الفاتورة
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.95, 0.95, 0.95, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "إجمالي الفاتورة"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                    Label:
                        text: root.total_amount
                        font_size: sp(28)
                        bold: True
                        font_name: 'ArabicFont'
                        color: (0.2, 0.5, 0.8, 1)
                
                # إطار الخصم
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.95, 0.95, 0.95, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "الخصم"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                    Label:
                        text: root.discount_amount
                        font_size: sp(24)
                        bold: True
                        font_name: 'ArabicFont'
                        color: (0.8, 0.2, 0.2, 1)
                
                # إطار الصافي
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.95, 0.95, 0.95, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "الصافي"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                    Label:
                        text: root.net_amount
                        font_size: sp(28)
                        bold: True
                        font_name: 'ArabicFont'
                        color: (0.2, 0.6, 0.2, 1)
                
                # أزرار التحكم
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(120)
                    spacing: dp(5)
                    
                    Button:
                        text: "✅ إنهاء الشراء"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.6, 0.2, 1)
                        size_hint_y: None
                        height: dp(50)
                        on_press: root.finish_purchase()
                    
                    Button:
                        text: "🗑️ مسح السلة"
                        font_name: 'ArabicFont'
                        background_color: (0.8, 0.2, 0.2, 1)
                        size_hint_y: None
                        height: dp(50)
                        on_press: root.clear_cart()
            
            # الجهة اليمنى: المحتوى الرئيسي
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.72
                spacing: dp(10)
                
                # إطار اختيار المورد
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    padding: dp(10)
                    spacing: dp(10)
                    
                    Label:
                        text: "اختر المورد:"
                        font_size: sp(14)
                        bold: True
                        font_name: 'ArabicFont'
                        size_hint_x: None
                        width: dp(100)
                    
                    Spinner:
                        text: root.supplier_name
                        values: root.suppliers_list
                        font_name: 'ArabicFont'
                        font_size: sp(14)
                        size_hint_x: 0.5
                        on_text: root.supplier_name = self.text
                
                # إطار الإدخال
                BoxLayout:
                    size_hint_y: None
                    height: dp(80)
                    padding: dp(10)
                    spacing: dp(10)
                    
                    TextInput:
                        text: root.barcode
                        hint_text: "الباركود"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                        multiline: False
                        size_hint_x: 0.4
                        on_text: root.barcode = self.text
                    
                    TextInput:
                        text: root.quantity
                        hint_text: "الكمية"
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                        multiline: False
                        input_filter: 'int'
                        size_hint_x: 0.15
                        on_text: root.quantity = self.text
                    
                    Button:
                        text: "➕ إضافة الصنف"
                        font_name: 'ArabicFont'
                        background_color: (0.2, 0.5, 0.8, 1)
                        size_hint_x: 0.25
                        on_press: root.add_to_cart()
                
                # إطار الخصم
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    padding: dp(10)
                    spacing: dp(10)
                    
                    Label:
                        text: "قيمة الخصم:"
                        font_size: sp(14)
                        bold: True
                        font_name: 'ArabicFont'
                        size_hint_x: None
                        width: dp(100)
                    
                    TextInput:
                        text: root.discount_amount
                        font_size: sp(14)
                        font_name: 'ArabicFont'
                        multiline: False
                        input_filter: 'float'
                        size_hint_x: 0.2
                        on_text: 
                            root.discount_amount = self.text
                            root.update_totals()
                
                # رأس جدول السلة
                BoxLayout:
                    size_hint_y: None
                    height: dp(45)
                    spacing: dp(5)
                    padding: dp(5)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.3, 0.4, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                    Label:
                        text: "الباركود"
                        size_hint_x: 0.15
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "اسم الصنف"
                        size_hint_x: 0.3
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "سعر الشراء"
                        size_hint_x: 0.12
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "الكمية"
                        size_hint_x: 0.1
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: "الإجمالي"
                        size_hint_x: 0.12
                        font_name: 'ArabicFont'
                        color: (1, 1, 1, 1)
                    Label:
                        text: ""
                        size_hint_x: 0.08
                        font_name: 'ArabicFont'
                
                # قائمة السلة
                RecycleView:
                    id: cart_list
                    viewclass: 'PurchaseItem'
                    
                    RecycleBoxLayout:
                        default_size: (None, dp(50))
                        default_size_hint: (1, None)
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: 'vertical'