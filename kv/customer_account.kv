<TransactionItem>:
    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(5)
        
        Label:
            text: root.date
            size_hint_x: 0.25
            font_name: 'ArabicFont'
        
        Label:
            text: root.type
            size_hint_x: 0.2
            font_name: 'ArabicFont'
            color: (0.2, 0.5, 0.8, 1) if root.type == "فاتورة مبيعات" else (0.8, 0.2, 0.2, 1) if root.type == "دفعة" else (0.8, 0.5, 0.2, 1)
        
        Label:
            text: root.amount
            size_hint_x: 0.2
            font_name: 'ArabicFont'
        
        Label:
            text: root.details
            size_hint_x: 0.35
            font_name: 'ArabicFont'
            halign: 'right'
            text_size: self.size


<CustomerAccountScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "كشف حساب الزبون: " + root.customer_name
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        # إحصائيات
        GridLayout:
            size_hint_y: None
            height: dp(100)
            cols: 4
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                Label:
                    text: "إجمالي المشتريات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_purchases
                    font_size: sp(18)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.6, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                Label:
                    text: "إجمالي المدفوعات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_payments
                    font_size: sp(18)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.8, 0.2, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                Label:
                    text: "إجمالي المرتجعات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_returns
                    font_size: sp(18)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.8, 0.5, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                Label:
                    text: "الرصيد الحالي"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.current_balance
                    font_size: sp(18)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.5, 0.8, 1)
        
        # رأس الجدول
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "التاريخ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "نوع الحركة"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المبلغ"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "التفاصيل"
                size_hint_x: 0.35
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: transactions_list
            viewclass: 'TransactionItem'