<TransactionItem>:
    # هذا المكون يمثل كل سطر في كشف الحساب
    size_hint_y: None
    height: dp(40)
    canvas.before:
        Color:
            rgba: (0.95, 0.95, 0.95, 1) if root.index % 2 == 0 else (1, 1, 1, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(5)
        
        Label:
            text: root.date
            size_hint_x: 0.25
            font_name: 'ArabicFont'
            color: (0, 0, 0, 1)
        
        Label:
            text: root.type
            size_hint_x: 0.2
            font_name: 'ArabicFont'
            # إصلاح منطق الألوان ليكون أكثر وضوحاً ومقاومة للأخطاء
            color: (0.2, 0.5, 0.8, 1) if "فاتورة" in root.type else (0.8, 0.2, 0.2, 1) if "دفعة" in root.type else (0.8, 0.5, 0.2, 1)
        
        Label:
            text: str(root.amount)
            size_hint_x: 0.2
            font_name: 'ArabicFont'
            color: (0, 0, 0, 1)
        
        Label:
            text: root.details
            size_hint_x: 0.35
            font_name: 'ArabicFont'
            halign: 'right'
            valign: 'middle'
            text_size: self.size
            color: (0.3, 0.3, 0.3, 1)


<CustomerAccountScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # الرأس (Header)
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: (0.1, 0.4, 0.6, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "كشف حساب: " + root.customer_name
                font_size: sp(20)
                bold: True
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_normal: ''
                background_color: (0.8, 0.3, 0.3, 1)
                on_press: root.go_back()
        
        # قسم الإحصائيات (Cards Style)
        GridLayout:
            size_hint_y: None
            height: dp(100)
            cols: 4
            spacing: dp(10)
            
            # كرت إجمالي المشتريات
            StatsCard:
                title: "المشتريات"
                value: root.total_purchases
                v_color: (0.2, 0.6, 0.2, 1)
            
            StatsCard:
                title: "المدفوعات"
                value: root.total_payments
                v_color: (0.8, 0.2, 0.2, 1)

            StatsCard:
                title: "المرتجعات"
                value: root.total_returns
                v_color: (0.8, 0.5, 0.2, 1)

            StatsCard:
                title: "الرصيد"
                value: root.current_balance
                v_color: (0.2, 0.5, 0.8, 1)
        
        # رأس جدول الحركات
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: [0, dp(5)]
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            TableHeaderLabel:
                text: "التاريخ"
                size_hint_x: 0.25
            TableHeaderLabel:
                text: "النوع"
                size_hint_x: 0.2
            TableHeaderLabel:
                text: "المبلغ"
                size_hint_x: 0.2
            TableHeaderLabel:
                text: "التفاصيل"
                size_hint_x: 0.35
        
        # القائمة (RecycleView)
        RecycleView:
            id: transactions_list
            viewclass: 'TransactionItem'
            RecycleBoxLayout:
                default_size: None, dp(45)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'

# قوالب مساعدة لتقليل تكرار الكود
<StatsCard@BoxLayout>:
    orientation: 'vertical'
    title: ''
    value: ''
    v_color: (0,0,0,1)
    canvas.before:
        Color:
            rgba: (0.9, 0.9, 0.9, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]
    Label:
        text: root.title
        font_size: sp(12)
        font_name: 'ArabicFont'
        color: (0.4, 0.4, 0.4, 1)
    Label:
        text: root.value
        font_size: sp(16)
        bold: True
        font_name: 'ArabicFont'
        color: root.v_color

<TableHeaderLabel@Label>:
    font_name: 'ArabicFont'
    bold: True
    color: (1, 1, 1, 1)