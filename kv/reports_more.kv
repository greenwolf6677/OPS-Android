# ==================== تقرير المبيعات حسب المستخدم ====================
<SalesByUserItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.rank)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: root.user_name
        size_hint_x: 0.27
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: str(root.invoices_count)
        size_hint_x: 0.12
        font_name: 'ArabicFont'
    
    Label:
        text: str(root.items_count)
        size_hint_x: 0.12
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total_sales:.2f}"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: f"{root.avg_per_invoice:.2f}"
        size_hint_x: 0.13
        font_name: 'ArabicFont'


<InvoiceDetailItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(40)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.date
        size_hint_x: 0.25
        font_name: 'ArabicFont'
    
    Label:
        text: root.invoice_id
        size_hint_x: 0.25
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total:.2f}"
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: str(root.items_count)
        size_hint_x: 0.15
        font_name: 'ArabicFont'


<SalesByUserReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "👤 المبيعات حسب المستخدم"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "من تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.start_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_start_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "إلى تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.end_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_end_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "المستخدم"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Spinner:
                    text: root.selected_user
                    values: root.users_list
                    font_name: 'ArabicFont'
                    size_hint_y: None
                    height: dp(40)
                    on_text: root.selected_user = self.text; root.load_report()
            
            Button:
                text: "عرض التقرير 🔍"
                font_name: 'ArabicFont'
                background_color: (0.2, 0.6, 0.2, 1)
                size_hint_x: None
                width: dp(120)
                on_press: root.load_report()
        
        GridLayout:
            size_hint_y: None
            height: dp(80)
            cols: 3
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "إجمالي المبيعات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_sales
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.6, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "عدد الفواتير"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_invoices
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.5, 0.8, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "عدد الأصناف"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_items
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.8, 0.5, 0.2, 1)
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "ر"
                size_hint_x: 0.08
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "اسم المستخدم"
                size_hint_x: 0.27
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "عدد الفواتير"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "عدد الأصناف"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "إجمالي المبيعات"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "متوسط الفاتورة"
                size_hint_x: 0.13
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: users_list
            viewclass: 'SalesByUserItem'
            on_selection: 
                if self.selection: root.load_invoice_details(self.selection[0].user_name)
        
        BoxLayout:
            size_hint_y: None
            height: dp(35)
            padding: dp(5)
            Label:
                text: "تفاصيل الفواتير للمستخدم المختار:"
                font_size: sp(14)
                bold: True
                font_name: 'ArabicFont'
                halign: 'right'
        
        BoxLayout:
            size_hint_y: None
            height: dp(35)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "التاريخ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "رقم الفاتورة"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "عدد الأصناف"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: invoice_details_list
            viewclass: 'InvoiceDetailItem'


# ==================== تقرير المبيعات حسب طريقة الدفع ====================
<PaymentMethodItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(50)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.method
        size_hint_x: 0.25
        font_name: 'ArabicFont'
        font_size: sp(14)
        bold: True
    
    Label:
        text: str(root.total_sales)
        size_hint_x: 0.2
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total_amount:.2f}"
        size_hint_x: 0.25
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: f"{root.percentage:.1f}%"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        color: (0.2, 0.5, 0.8, 1)


<PaymentMethodReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "💳 المبيعات حسب طريقة الدفع"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "من تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.start_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_start_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "إلى تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.end_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_end_date_picker()
            
            Button:
                text: "عرض التقرير 🔍"
                font_name: 'ArabicFont'
                background_color: (0.2, 0.6, 0.2, 1)
                size_hint_x: None
                width: dp(120)
                on_press: root.load_report()
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "طريقة الدفع"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "عدد المعاملات"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "إجمالي المبلغ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "النسبة المئوية"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: payment_methods_list
            viewclass: 'PaymentMethodItem'
            on_selection: 
                if self.selection: root.on_method_select(self.selection[0].method)
        
        BoxLayout:
            size_hint_y: None
            height: dp(35)
            padding: dp(5)
            Label:
                text: "تفاصيل المبيعات:"
                font_size: sp(14)
                bold: True
                font_name: 'ArabicFont'
                halign: 'right'
        
        BoxLayout:
            size_hint_y: None
            height: dp(35)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "التاريخ"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "رقم الفاتورة"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الزبون"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "عدد الأصناف"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: invoice_details_list
            viewclass: 'InvoiceDetailItem'
            item_class: InvoiceDetailItem


# ==================== تقرير المشتريات ====================
<PurchaseItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.date
        size_hint_x: 0.25
        font_name: 'ArabicFont'
    
    Label:
        text: root.supplier
        size_hint_x: 0.3
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: f"{root.total:.2f}"
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: str(root.items_count)
        size_hint_x: 0.12
        font_name: 'ArabicFont'


<PurchaseDetailItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(40)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.purchase_id)
        size_hint_x: 0.15
        font_name: 'ArabicFont'
    
    Label:
        text: root.product
        size_hint_x: 0.35
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: str(root.quantity)
        size_hint_x: 0.1
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.price:.2f}"
        size_hint_x: 0.12
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.subtotal:.2f}"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)


<PurchasesReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "📥 تقرير المشتريات"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
