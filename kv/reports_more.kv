                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "من تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.start_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_start_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "إلى تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.end_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_end_date_picker()
            
            Button:
                text: "عرض التقرير 🔍"
                font_name: 'ArabicFont'
                background_color: (0.2, 0.6, 0.2, 1)
                size_hint_x: None
                width: dp(120)
                on_press: root.load_report()
        
        GridLayout:
            size_hint_y: None
            height: dp(80)
            cols: 3
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "إجمالي المشتريات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_purchases
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.6, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "عدد الأصناف"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_items
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.5, 0.8, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "عدد الفواتير"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_invoices
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.8, 0.5, 0.2, 1)
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "التاريخ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المورد"
                size_hint_x: 0.3
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "إجمالي الفاتورة"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "عدد الأصناف"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: purchases_list
            viewclass: 'PurchaseItem'
            on_selection: 
                if self.selection: root.on_purchase_select(self.selection[0].date, self.selection[0].total)
        
        BoxLayout:
            size_hint_y: None
            height: dp(35)
            padding: dp(5)
            Label:
                text: "تفاصيل الفاتورة المحددة:"
                font_size: sp(14)
                bold: True
                font_name: 'ArabicFont'
                halign: 'right'
        
        BoxLayout:
            size_hint_y: None
            height: dp(35)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "رقم الفاتورة"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "اسم المنتج"
                size_hint_x: 0.35
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الكمية"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "سعر الشراء"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: purchase_details_list
            viewclass: 'PurchaseDetailItem'


# ==================== تقرير حركة المخزون ====================
<InventoryMovementItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.date
        size_hint_x: 0.15
        font_name: 'ArabicFont'
    
    Label:
        text: root.product
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: root.type
        size_hint_x: 0.1
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1) if root.type == "مبيعات" else (0.8, 0.4, 0.2, 1)
    
    Label:
        text: str(root.qty)
        size_hint_x: 0.08
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.price:.2f}"
        size_hint_x: 0.1
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total:.2f}"
        size_hint_x: 0.12
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: root.reference
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size


<InventoryReportScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            Label:
                text: "📦 تقرير حركة المخزون"
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "من تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.start_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_start_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "إلى تاريخ"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                Button:
                    text: root.end_date
                    font_name: 'ArabicFont'
                    background_color: (0.3, 0.3, 0.3, 1)
                    size_hint_y: None
                    height: dp(40)
                    on_press: root.open_end_date_picker()
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                Label:
                    text: "اسم المنتج"
                    font_size: sp(12)
                    font_name: 'ArabicFont'
                TextInput:
                    text: root.product_filter
                    hint_text: "بحث عن منتج..."
                    font_name: 'ArabicFont'
                    size_hint_y: None
                    height: dp(40)
                    on_text: root.product_filter = self.text
            
            Button:
                text: "عرض التقرير 🔍"
                font_name: 'ArabicFont'
                background_color: (0.2, 0.6, 0.2, 1)
                size_hint_x: None
                width: dp(120)
                on_press: root.load_report()
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "التاريخ"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "اسم المنتج"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "النوع"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الكمية"
                size_hint_x: 0.08
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "السعر"
                size_hint_x: 0.1
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.12
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المرجع"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: movements_list
            viewclass: 'InventoryMovementItem'