# ==================== شاشة فواتير المورد ====================
<InvoiceItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.purchase_id)
        size_hint_x: 0.2
        font_name: 'ArabicFont'
    
    Label:
        text: root.date
        size_hint_x: 0.4
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.total:.2f}"
        size_hint_x: 0.25
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Button:
        text: "عرض التفاصيل"
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        background_color: (0.2, 0.5, 0.8, 1)
        on_press: 
            app.root.get_screen('supplier_invoices').load_invoice_details(root.purchase_id, root.total)


<InvoiceDetailItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(40)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.name
        size_hint_x: 0.45
        font_name: 'ArabicFont'
        halign: 'right'
        text_size: self.size
    
    Label:
        text: str(root.quantity)
        size_hint_x: 0.15
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.price:.2f}"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.subtotal:.2f}"
        size_hint_x: 0.2
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)


<SupplierInvoicesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "فواتير المورد: " + root.supplier_name
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
            
            Button:
                text: "🖨️ طباعة الفاتورة"
                size_hint_x: None
                width: dp(150)
                font_name: 'ArabicFont'
                background_color: (0.2, 0.5, 0.7, 1)
                on_press: root.print_invoice()
        
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "رقم الفاتورة"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "التاريخ"
                size_hint_x: 0.4
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: ""
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: invoices_list
            viewclass: 'InvoiceItem'
        
        Label:
            text: "تفاصيل الفاتورة المحددة:"
            font_size: sp(14)
            bold: True
            font_name: 'ArabicFont'
            size_hint_y: None
            height: dp(35)
        
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "اسم المنتج"
                size_hint_x: 0.45
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الكمية"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "سعر الشراء"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: details_list
            viewclass: 'InvoiceDetailItem'


# ==================== شاشة مدفوعات المورد ====================
<PaymentItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: str(root.payment_id)
        size_hint_x: 0.2
        font_name: 'ArabicFont'
    
    Label:
        text: f"{root.amount:.2f}"
        size_hint_x: 0.3
        font_name: 'ArabicFont'
        color: (0.2, 0.6, 0.2, 1)
    
    Label:
        text: root.date
        size_hint_x: 0.45
        font_name: 'ArabicFont'


<SupplierPaymentsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "مدفوعات المورد: " + root.supplier_name
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: (0.95, 0.95, 0.95, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "إجمالي المدفوعات:"
                font_size: sp(16)
                font_name: 'ArabicFont'
            Label:
                text: root.total_paid
                font_size: sp(28)
                bold: True
                font_name: 'ArabicFont'
                color: (0.2, 0.6, 0.2, 1)
        
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "ID"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المبلغ"
                size_hint_x: 0.3
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "تاريخ الدفع"
                size_hint_x: 0.45
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: payments_list
            viewclass: 'PaymentItem'


# ==================== شاشة كشف حساب المورد ====================
<TransactionItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    spacing: dp(5)
    padding: [dp(5), dp(5)]
    
    Label:
        text: root.date
        size_hint_x: 0.35
        font_name: 'ArabicFont'
    
    Label:
        text: root.type
        size_hint_x: 0.25
        font_name: 'ArabicFont'
        color: (0.2, 0.5, 0.8, 1) if root.type == "فاتورة شراء" else (0.2, 0.6, 0.2, 1)
    
    Label:
        text: f"{root.amount:.2f}"
        size_hint_x: 0.25
        font_name: 'ArabicFont'


<SupplierAccountScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "كشف حساب المورد: " + root.supplier_name
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        GridLayout:
            size_hint_y: None
            height: dp(100)
            cols: 3
            spacing: dp(10)
            padding: dp(10)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "إجمالي المشتريات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_purchases
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.5, 0.8, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "إجمالي المدفوعات"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.total_payments
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: (0.2, 0.6, 0.2, 1)
            
            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "الرصيد الحالي"
                    font_size: sp(14)
                    font_name: 'ArabicFont'
                Label:
                    text: root.balance
                    font_size: sp(24)
                    bold: True
                    font_name: 'ArabicFont'
                    color: root.balance_color
        
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "التاريخ"
                size_hint_x: 0.35
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "نوع الحركة"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "المبلغ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: transactions_list
            viewclass: 'TransactionItem'