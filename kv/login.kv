<LoginScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(15)
        
        # الشعار
        BoxLayout:
            size_hint_y: 0.25
            Label:
                text: "OPS"
                font_size: sp(56)
                bold: True
                font_name: 'ArabicFont'
                color: (0.2, 0.6, 0.2, 1)
        
        Label:
            text: "Orders Processing System"
            font_size: sp(18)
            color: (0.6, 0.6, 0.6, 1)
            font_name: 'ArabicFont'
        
        # حقول الإدخال
        BoxLayout:
            size_hint_y: 0.12
            spacing: dp(10)
            Label:
                text: "اسم المستخدم:"
                size_hint_x: 0.3
                font_size: sp(18)
                font_name: 'ArabicFont'
                halign: 'right'
                text_size: self.size
            TextInput:
                text: root.username
                hint_text: "أدخل اسم المستخدم"
                font_size: sp(16)
                font_name: 'ArabicFont'
                multiline: False
                size_hint_x: 0.7
                on_text: root.username = self.text
        
        BoxLayout:
            size_hint_y: 0.12
            spacing: dp(10)
            Label:
                text: "كلمة المرور:"
                size_hint_x: 0.3
                font_size: sp(18)
                font_name: 'ArabicFont'
                halign: 'right'
                text_size: self.size
            BoxLayout:
                size_hint_x: 0.7
                spacing: dp(5)
                TextInput:
                    text: root.password
                    hint_text: "أدخل كلمة المرور"
                    font_size: sp(16)
                    font_name: 'ArabicFont'
                    multiline: False
                    password: not root.show_password
                    on_text: root.password = self.text
                Button:
                    text: "👁" if root.show_password else "🙈"
                    size_hint_x: 0.15
                    background_color: (0.3, 0.3, 0.3, 1)
                    on_press: root.toggle_password()
        
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(20)
            CheckBox:
                active: root.remember_me
                on_active: root.remember_me = self.active
            Label:
                text: "تذكر اسم المستخدم"
                font_size: sp(16)
                font_name: 'ArabicFont'
        
        Label:
            text: root.error_message
            color: (0.9, 0.2, 0.2, 1)
            font_size: sp(14)
            font_name: 'ArabicFont'
        
        Button:
            text: "دخول"
            font_size: sp(20)
            bold: True
            font_name: 'ArabicFont'
            background_color: (0.2, 0.6, 0.2, 1)
            size_hint_y: 0.1
            on_press: root.check_login()
        
        Label:
            text: f"النسخة 1.0.0"
            font_size: sp(12)
            color: (0.6, 0.6, 0.6, 1)
            font_name: 'ArabicFont'