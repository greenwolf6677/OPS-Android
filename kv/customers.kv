# نافذة تسجيل الدفعة
<PaymentPopup>:
    orientation: 'vertical'
    padding: dp(15)
    spacing: dp(10)
    Label:
        text: "تسجيل دفعة للزبون: " + root.customer_name
        font_name: 'ArabicFont'
    TextInput:
        id: amt
        hint_text: "المبلغ المدفوع"
        input_filter: 'float'
        multiline: False
    TextInput:
        id: nts
        hint_text: "ملاحظات (اختياري)"
        font_name: 'ArabicFont'
    Button:
        text: "تأكيد وحفظ الدفعة"
        background_color: [0.1, 0.6, 0.1, 1]
        on_release: 
            root.save_payment(amt.text, nts.text)
            app.root.get_screen('customers')._popup.dismiss()

# شكل الزبون في القائمة (RecycleView Item)
<CustomerItemWidget@BoxLayout>:
    c_id: ''; c_name: ''; c_phone: ''; c_balance: ''; c_color: [1,1,1,1]
    c_address: ''; c_notes: ''; c_initial: ''
    index: 0
    
    orientation: 'horizontal'
    padding: dp(5)
    spacing: dp(8)
    size_hint_y: None
    height: dp(95) # ارتفاع كافٍ للأزرار
    canvas.before:
        Color: rgba: 0.12, 0.12, 0.12, 1
        RoundedRectangle: size: self.size, pos: self.pos, radius: [8]

    # أزرار العمليات على اليسار
    GridLayout:
        cols: 2
        size_hint_x: 0.45
        spacing: dp(3)
        Button:
            text: "حذف"
            background_color: [0.8, 0.2, 0.2, 1]
            on_release: app.root.get_screen('customers').delete_customer(root.c_id)
        Button:
            text: "فواتير"
            on_release: app.root.get_screen('customers').view_invoices(root.c_id)
        Button:
            text: "تعديل"
            on_release: app.root.get_screen('customers').select_customer_for_edit(root)
        Button:
            text: "قبض $"
            background_color: [0.2, 0.6, 0.4, 1]
            on_release: 
                app.root.get_screen('customers').select_customer_for_edit(root)
                app.root.get_screen('customers').show_payment_popup()

    # بيانات الزبون على اليمين
    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.55
        Label:
            text: root.c_name
            font_name: 'ArabicFont'
            halign: 'right'
            text_size: self.size
            bold: True
            font_size: '16sp'
        Label:
            text: "الهاتف: " + root.c_phone
            font_size: '12sp'
            halign: 'right'
            text_size: self.size
            color: 0.7, 0.7, 0.7, 1
        Label:
            text: root.c_balance
            color: root.c_color
            halign: 'right'
            text_size: self.size
            bold: True
            font_size: '15sp'

<CustomersScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)

        # 1. شريط الإحصائيات العلوي
        BoxLayout:
            size_hint_y: 0.08
            canvas.before:
                Color: rgba: 0.2, 0.2, 0.2, 1
                RoundedRectangle: size: self.size, pos: self.pos, radius: [5]
            Label:
                text: "إجمالي الديون: " + root.total_debt
                font_name: 'ArabicFont'
            Label:
                text: "عدد الزبائن: " + root.total_customers
                font_name: 'ArabicFont'

        # 2. منطقة الإدخال (اسم، هاتف، عنوان، رصيد)
        GridLayout:
            cols: 2
            size_hint_y: 0.25
            spacing: dp(5)
            TextInput:
                text: root.customer_name
                hint_text: "اسم الزبون الكامل"
                on_text: root.customer_name = self.text
                font_name: 'ArabicFont'
                multiline: False
            TextInput:
                text: root.phone
                hint_text: "رقم الهاتف"
                on_text: root.phone = self.text
                input_filter: 'int'
            TextInput:
                text: root.address
                hint_text: "العنوان"
                on_text: root.address = self.text
                font_name: 'ArabicFont'
            TextInput:
                text: root.balance
                hint_text: "الرصيد الافتتاحي (مدين)"
                on_text: root.balance = self.text
                input_filter: 'float'

        # 3. أزرار التحكم الرئيسية
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(10)
            Button:
                text: "حفظ البيانات"
                background_color: [0, 0.5, 0, 1]
                on_release: root.save_customer()
                font_name: 'ArabicFont'
            Button:
                text: "تفريغ الحقول"
                on_release: root.clear_fields()
                font_name: 'ArabicFont'

        # 4. قائمة الزبائن (RecycleView)
        RecycleView:
            id: customers_rv
            viewclass: 'CustomerItemWidget'
            RecycleBoxLayout:
                default_size: None, dp(95)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(6)

        # 5. زر العودة
        Button:
            text: "العودة للرئيسية"
            size_hint_y: 0.07
            on_release: root.manager.current = 'dashboard'
            font_name: 'ArabicFont'