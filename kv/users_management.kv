<UserItem>:
    canvas.before:
        Color:
            rgba: (0.15, 0.15, 0.15, 1) if root.user_id % 2 == 0 else (0.1, 0.1, 0.1, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    
    Label:
        text: str(root.user_id)
        size_hint_x: 0.1
        font_name: 'ArabicFont'
    Label:
        text: root.full_name
        size_hint_x: 0.4
        font_name: 'ArabicFont'
        halign: 'right'
    Label:
        text: root.username
        size_hint_x: 0.3
        font_name: 'ArabicFont'
    Label:
        text: "مدير" if root.role == 'admin' else "موظف"
        size_hint_x: 0.2
        font_name: 'ArabicFont'
    Button:
        text: "تعديل"
        size_hint_x: 0.15
        font_name: 'ArabicFont'
        on_release: app.root.get_screen('users_management').select_user(root.user_id, root.username, root.full_name, root.role)

<UsersManagementScreen>:
    name: 'users_management'
    
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.05, 0.05, 0.05, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # --- شريط العنوان ---
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: (0.1, 0.4, 0.6, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Button:
                text: "رجوع"
                size_hint_x: None
                width: dp(80)
                font_name: 'ArabicFont'
                on_release: root.go_back()
            
            Label:
                text: "إدارة المستخدمين والإعدادات"
                font_size: '20sp'
                font_name: 'ArabicFont'
                bold: True

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(15)
                spacing: dp(20)

                # --- قسم إعدادات المحل ---
                Label:
                    text: "إعدادات المحل والشعار"
                    font_name: 'ArabicFont'
                    size_hint_y: None
                    height: dp(30)
                    color: (0.1, 0.7, 1, 1)

                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(250)
                    spacing: dp(10)

                    BoxLayout:
                        orientation: 'vertical'
                        spacing: dp(5)
                        TextInput:
                            hint_text: "اسم المحل"
                            text: root.store_name
                            on_text: root.store_name = self.text
                            multiline: False
                            font_name: 'ArabicFont'
                        TextInput:
                            hint_text: "رقم الهاتف"
                            text: root.store_phone
                            on_text: root.store_phone = self.text
                            font_name: 'ArabicFont'
                        TextInput:
                            hint_text: "العنوان"
                            text: root.store_address
                            on_text: root.store_address = self.text
                            font_name: 'ArabicFont'

                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.4
                        canvas.before:
                            Color:
                                rgba: (0.2, 0.2, 0.2, 1)
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        
                        Image:
                            id: logo_preview
                            source: root.logo_path if root.logo_path else ''
                            allow_stretch: True
                        
                        Button:
                            text: "اختيار شعار"
                            size_hint_y: None
                            height: dp(40)
                            font_name: 'ArabicFont'
                            on_release: root.select_logo()

                Button:
                    text: "حفظ إعدادات المحل"
                    size_hint_y: None
                    height: dp(50)
                    background_color: (0.2, 0.6, 0.2, 1)
                    font_name: 'ArabicFont'
                    on_release: root.save_store_settings()

                # --- قسم إدارة المستخدمين ---
                Separator: # يمكنك تعريف كلاس Separator بسيط لرسم خط
                
                Label:
                    text: "إضافة / تعديل مستخدم"
                    font_name: 'ArabicFont'
                    size_hint_y: None
                    height: dp(30)
                    color: (0.1, 0.7, 1, 1)

                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(120)
                    spacing: dp(10)
                    
                    TextInput:
                        hint_text: "الاسم الكامل"
                        text: root.full_name
                        on_text: root.full_name = self.text
                        font_name: 'ArabicFont'
                    TextInput:
                        hint_text: "اسم المستخدم"
                        text: root.username
                        on_text: root.username = self.text
                        font_name: 'ArabicFont'
                    TextInput:
                        hint_text: "كلمة المرور"
                        password: True
                        text: root.password
                        on_text: root.password = self.text
                        font_name: 'ArabicFont'
                    
                    BoxLayout:
                        Label:
                            text: "مسؤول (Admin)"
                            font_name: 'ArabicFont'
                        CheckBox:
                            active: root.is_admin
                            on_active: root.is_admin = self.active

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(10)
                    Button:
                        text: "إضافة"
                        background_color: (0.1, 0.5, 0.8, 1)
                        font_name: 'ArabicFont'
                        on_release: root.add_user()
                    Button:
                        text: "تحديث"
                        background_color: (0.8, 0.6, 0.1, 1)
                        font_name: 'ArabicFont'
                        on_release: root.update_user()
                    Button:
                        text: "حذف"
                        background_color: (0.8, 0.1, 0.1, 1)
                        font_name: 'ArabicFont'
                        on_release: root.delete_user()

                # --- عرض القائمة ---
                RecycleView:
                    id: users_rv
                    data: [{'user_id': x['user_id'], 'username': x['username'], 'full_name': x['full_name'], 'role': x['role']} for x in root.users_list]
                    viewclass: 'UserItem'
                    size_hint_y: None
                    height: dp(200)
                    RecycleBoxLayout:
                        default_size: None, dp(50)
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: 'vertical'

                # --- قسم الصيانة ---
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(10)
                    Button:
                        text: "نسخة احتياطية"
                        font_name: 'ArabicFont'
                        on_release: root.create_backup()
                    Button:
                        text: "استرجاع نسخة"
                        font_name: 'ArabicFont'
                        on_release: root.restore_backup()
                    Button:
                        text: "تحديث النظام"
                        font_name: 'ArabicFont'
                        on_release: root.manual_update()

<Separator@Widget>:
    size_hint_y: None
    height: dp(2)
    canvas:
        Color:
            rgba: (0.3, 0.3, 0.3, 1)
        Rectangle:
            pos: self.pos
            size: self.size