<InvoiceItem>:
    # تم إضافة سياق الخلفية المتبادلة (Zebra Stripe)
    size_hint_y: None
    height: dp(50)
    canvas.before:
        Color:
            rgba: (0.98, 0.98, 0.98, 1) if root.index % 2 == 0 else (1, 1, 1, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(5)
        padding: [dp(5), 0]
        
        Label:
            text: root.invoice_id
            size_hint_x: 0.3
            font_name: 'ArabicFont'
            color: (0.1, 0.1, 0.1, 1)
        
        Label:
            text: root.date
            size_hint_x: 0.25
            font_name: 'ArabicFont'
            color: (0.3, 0.3, 0.3, 1)
        
        Label:
            text: str(root.total)
            size_hint_x: 0.15
            font_name: 'ArabicFont'
            color: (0.2, 0.6, 0.2, 1) # اللون الأخضر للإجمالي
            bold: True
        
        Label:
            text: root.payment_method
            size_hint_x: 0.15
            font_name: 'ArabicFont'
            color: (0.4, 0.4, 0.4, 1)
        
        # تحسين شكل الزر ليكون أصغر وأكثر تناسقاً
        AnchorLayout:
            size_hint_x: 0.15
            Button:
                text: "🔍" # أيقونة بدلاً من نص طويل للموبايل
                size_hint: (0.8, 0.7)
                font_name: 'ArabicFont'
                background_normal: ''
                background_color: (0.2, 0.5, 0.8, 1)
                on_press: 
                    # استخدام app.root.get_screen للوصول الآمن
                    app.root.get_screen('customer_invoices').select_invoice(root.invoice_id)


<CustomerInvoicesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # رأس الشاشة
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.4, 0.6, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [0, 0, dp(10), dp(10)]
            
            Label:
                text: "سجل فواتير: " + root.customer_name
                font_size: sp(18)
                bold: True
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            
            Button:
                text: "↩️"
                size_hint_x: None
                width: dp(50)
                font_name: 'ArabicFont'
                background_normal: ''
                background_color: (0, 0, 0, 0) # شفاف لإظهار الرمز فقط
                on_press: root.go_back()
        
        # رأس الجدول
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            padding: [dp(5), 0]
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            HeaderLabel:
                text: "رقم الفاتورة"
                size_hint_x: 0.3
            HeaderLabel:
                text: "التاريخ"
                size_hint_x: 0.25
            HeaderLabel:
                text: "الإجمالي"
                size_hint_x: 0.15
            HeaderLabel:
                text: "الدفع"
                size_hint_x: 0.15
            HeaderLabel:
                text: "تفاصيل"
                size_hint_x: 0.15
        
        # القائمة الفعالة
        RecycleView:
            id: invoices_list
            viewclass: 'InvoiceItem'
            RecycleBoxLayout:
                default_size: None, dp(50)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(2)

# تعريف الـ HeaderLabel لتقليل التكرار
<HeaderLabel@Label>:
    font_name: 'ArabicFont'
    bold: True
    font_size: sp(14)
    color: (1, 1, 1, 1)