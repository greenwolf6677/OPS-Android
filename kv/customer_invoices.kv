<InvoiceItem>:
    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(5)
        
        Label:
            text: root.invoice_id
            size_hint_x: 0.35
            font_name: 'ArabicFont'
        
        Label:
            text: root.date
            size_hint_x: 0.25
            font_name: 'ArabicFont'
        
        Label:
            text: root.total
            size_hint_x: 0.2
            font_name: 'ArabicFont'
            color: (0.2, 0.6, 0.2, 1)
        
        Label:
            text: root.payment_method
            size_hint_x: 0.15
            font_name: 'ArabicFont'
        
        Button:
            text: "عرض التفاصيل"
            size_hint_x: 0.15
            font_name: 'ArabicFont'
            background_color: (0.2, 0.5, 0.8, 1)
            on_press: 
                app.root.get_screen('customer_invoices').select_invoice(root.invoice_id)


<CustomerInvoicesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: dp(10)
            
            Label:
                text: "فواتير الزبون: " + root.customer_name
                font_size: sp(22)
                bold: True
                font_name: 'ArabicFont'
            
            Button:
                text: "↩️ رجوع"
                size_hint_x: None
                width: dp(100)
                font_name: 'ArabicFont'
                background_color: (0.5, 0.5, 0.5, 1)
                on_press: root.go_back()
        
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            padding: dp(5)
            canvas.before:
                Color:
                    rgba: (0.2, 0.3, 0.4, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                text: "رقم الفاتورة"
                size_hint_x: 0.35
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "التاريخ"
                size_hint_x: 0.25
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "الإجمالي"
                size_hint_x: 0.2
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: "طريقة الدفع"
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
            Label:
                text: ""
                size_hint_x: 0.15
                font_name: 'ArabicFont'
                color: (1, 1, 1, 1)
        
        RecycleView:
            id: invoices_list
            viewclass: 'InvoiceItem'